            "body": {
              "mode": "raw",
              "raw": "{\n  \"documents\": [\n    {\n      \"_index\": \"documents\",\n      \"_id\": \"react-hooks-001\",\n      \"_source\": {\n        \"title\": \"React Hooks Complete Guide\",\n        \"content\": \"Learn React Hooks from basics to advanced concepts. Covers useState, useEffect, useContext, and custom hooks.\",\n        \"author\": \"Jane Smith\",\n        \"category\": \"programming\",\n        \"tags\": [\"react\", \"hooks\", \"frontend\"],\n        \"difficulty\": \"intermediate\",\n        \"rating\": 4.6,\n        \"published\": true,\n        \"created_at\": \"2024-01-20T14:15:00Z\"\n      }\n    },\n    {\n      \"_index\": \"documents\",\n      \"_id\": \"python-ml-002\",\n      \"_source\": {\n        \"title\": \"Python Machine Learning Fundamentals\",\n        \"content\": \"Introduction to machine learning with Python using scikit-learn, pandas, and numpy. Covers supervised and unsupervised learning.\",\n        \"author\": \"Mike Johnson\",\n        \"category\": \"ai\",\n        \"tags\": [\"python\", \"machine-learning\", \"data-science\"],\n        \"difficulty\": \"beginner\",\n        \"rating\": 4.4,\n        \"published\": true,\n        \"created_at\": \"2024-01-18T09:45:00Z\"\n      }\n    },\n    {\n      \"_index\": \"documents\",\n      \"_id\": \"docker-guide-003\",\n      \"_source\": {\n        \"title\": \"Docker Containerization Guide\",\n        \"content\": \"Complete guide to Docker containerization. Learn how to create, manage, and deploy Docker containers in production.\",\n        \"author\": \"Sarah Wilson\",\n        \"category\": \"devops\",\n        \"tags\": [\"docker\", \"containers\", \"deployment\"],\n        \"difficulty\": \"intermediate\",\n        \"rating\": 4.7,\n        \"published\": true,\n        \"created_at\": \"2024-01-22T16:30:00Z\"\n      }\n    }\n  ],\n  \"index\": \"documents\",\n  \"pipeline\": \"text_processing\",\n  \"refresh\": \"wait_for\"\n}"
