              "raw": "{\n  \"document\": {\n    \"title\": \"Advanced JavaScript Patterns\",\n    \"content\": \"This comprehensive guide covers advanced JavaScript design patterns including module pattern, observer pattern, and factory pattern. Learn how to write maintainable and scalable JavaScript code.\",\n    \"author\": \"John Doe\",\n    \"category\": \"programming\",\n    \"tags\": [\"javascript\", \"patterns\", \"advanced\", \"tutorial\"],\n    \"difficulty\": \"advanced\",\n    \"rating\": 4.8,\n    \"published\": true,\n    \"created_at\": \"2024-01-15T10:30:00Z\",\n    \"metadata\": {\n      \"source\": \"blog\",\n      \"language\": \"en\",\n      \"word_count\": 2500,\n      \"reading_time\": 12\n    }\n  },\n  \"index\": \"documents\",\n  \"id\": \"js-patterns-001\",\n  \"pipeline\": \"text_processing\",\n  \"refresh\": \"wait_for\",\n  \"routing\": \"programming\"\n}"
            },
            "url": {
