        {
          "name": "Aggregation Search",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"programming tutorial\",\n  \"fields\": [\"title\", \"content\"],\n  \"index\": \"documents\",\n  \"filters\": {\n    \"status\": \"published\",\n    \"created_at\": {\n      \"gte\": \"2023-01-01\"\n    }\n  },\n  \"aggregations\": {\n    \"categories\": {\n      \"type\": \"terms\",\n      \"field\": \"category\",\n      \"size\": 10,\n      \"order\": {\n        \"_count\": \"desc\"\n      }\n    },\n    \"monthly_posts\": {\n      \"type\": \"date_histogram\",\n      \"field\": \"created_at\",\n      \"interval\": \"month\",\n      \"format\": \"yyyy-MM\",\n      \"min_doc_count\": 1\n    },\n    \"rating_ranges\": {\n      \"type\": \"range\",\n      \"field\": \"rating\",\n      \"ranges\": [\n        {\"to\": 2.0, \"key\": \"poor\"},\n        {\"from\": 2.0, \"to\": 3.5, \"key\": \"average\"},\n        {\"from\": 3.5, \"to\": 4.5, \"key\": \"good\"},\n        {\"from\": 4.5, \"key\": \"excellent\"}\n      ]\n    },\n    \"stats\": {\n      \"type\": \"stats\",\n      \"field\": \"rating\"\n    },\n    \"unique_authors\": {\n      \"type\": \"cardinality\",\n      \"field\": \"author.keyword\",\n      \"precision_threshold\": 1000\n    }\n  },\n  \"size\": 0,\n  \"timeout\": \"30s\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/search/aggregate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "search", "aggregate"]
            }
          }
        }
