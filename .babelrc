{
      "presets": [
        [
          "@babel/preset-env",
          {
            "targets": {
              "node": "18"
            },
            "modules": false
          }
        ]
      ],
      "plugins": [
        "@babel/plugin-transform-runtime",
        "@babel/plugin-transform-class-properties",
        "@babel/plugin-transform-object-rest-spread"
      ],
      "env": {
        "development": {
          "plugins": [
            "source-map-support"
          ]
        }
      }
    }
