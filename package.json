{
  "name": "auth_service_backend",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/Harmeet10000/production-grade-auth-template#readme",
  "bugs": {
    "url": "https://github.com/Harmeet10000/production-grade-auth-template/issues"
  },
  "license": "ISC",
  "author": "Harmeet Singh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harmeet10000/production-grade-auth-template.git"
  },
  "type": "module",
  "main": "index.js",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "bun --watch src/index.js",
    "build": "bun run build:clean && bun run build:bundle",
    "build:clean": "rm -rf dist",
    "build:bundle": "bun run scripts/bun-build.js",
    "start": "bun run dist/index.js",
    "swagger": "bun run ./docs/swagger.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "husky",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix",
    "format": "bunx oxfmt --write",
    "format:check": "bunx oxfmt --check",
    "check": "bun lint && bun format:check",
    "migrate:gen": "bunx drizzle-kit generate",
    "migrate:exec": "bun run src/db/migrate.js",
    "seed": "bun run src/db/seeders/index.js",
    "studio": "bunx drizzle-kit studio",
    "mig:push": "bunx drizzle-kit push",
    "mig:drop": "bunx drizzle-kit drop",
    "backup:start": "bun run scripts/dbBackup.js",
    "backup:once": "RUN_BACKUP_ONCE=true bun run scripts/dbBackup.js",
    "security:test": "bunx snyk test",
    "security:monitor": "bunx snyk monitor",
    "security:fix": "bunx snyk fix",
    "security:wizard": "bunx snyk wizard",
    "snyk:setup": "bash scripts/snyk-setup.sh"
  },
  "dependencies": {
    "@aws-sdk/client-personalize": "3.896.0",
    "@aws-sdk/client-personalize-events": "3.896.0",
    "@aws-sdk/client-personalize-runtime": "3.896.0",
    "@aws-sdk/client-s3": "3.901.0",
    "@aws-sdk/s3-request-presigner": "3.797.0",
    "@elastic/elasticsearch": "9.1.1",
    "@google/genai": "1.21.0",
    "@knocklabs/node": "1.28.0",
    "@neondatabase/serverless": "1.0.2",
    "@novu/node": "2.6.6",
    "@openfga/sdk": "0.9.0",
    "@paralleldrive/cuid2": "2.2.2",
    "@platformatic/kafka": "1.26.0",
    "amqplib": "0.10.7",
    "bcryptjs": "^3.0.2",
    "better-auth": "1.3.29",
    "bottleneck": "2.19.5",
    "busboy": "1.6.0",
    "colorette": "^2.0.20",
    "compression": "1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "countries-and-timezones": "^3.7.2",
    "date-fns": "4.1.0",
    "dayjs": "^1.11.18",
    "dotenv-flow": "4.1.0",
    "drizzle-orm": "0.44.6",
    "express": "^4.21.2",
    "express-async-handler": "1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-prom-bundle": "8.0.0",
    "express-rate-limit": "^7.5.0",
    "express-timeout-handler": "2.2.2",
    "fast-glob": "3.3.3",
    "fast-json-stringify": "6.3.0",
    "fastify-formbody": "5.3.0",
    "googleapis": "164.1.0",
    "helmet": "^8.0.0",
    "hpp": "0.2.3",
    "ioredis": "5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.23",
    "mongoose": "^8.10.1",
    "msgpackr": "1.11.8",
    "nanoid": "5.1.5",
    "neverthrow": "8.2.0",
    "node-cron": "^3.0.3",
    "overload-protection": "1.2.3",
    "p-retry": "7.1.1",
    "prom-client": "15.1.3",
    "rabbitmq-client": "5.0.8",
    "rabbitmq-stream-js-client": "1.0.0",
    "rate-limit-redis": "4.2.1",
    "razorpay": "2.9.6",
    "resend": "^4.2.0",
    "simdjson": "0.9.2",
    "sonic": "0.2.3",
    "source-map-support": "^0.5.21",
    "superjson": "2.2.2",
    "undici": "7.22.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-loki": "6.1.3",
    "winston-mongodb": "^6.0.0",
    "xxhashjs": "0.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@types/bun": "1.3.9",
    "drizzle-kit": "0.31.5",
    "glob": "11.0.3",
    "globals": "16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "oxfmt": "0.34.0",
    "oxlint": "1.49.0",
    "oxlint-tsgolint": "0.14.1",
    "supertest": "^7.1.0",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "6.2.8",
    "swagger-model-validator": "3.0.21",
    "swagger-ui-express": "^5.0.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bunx oxfmt --write",
      "bunx oxlint --fix"
    ]
  },
  "config": {
    "unsafe-perm": true
  },
  "engines": {
    "node": ">=22.14.0",
    "bun": ">=1.3.8"
  }
}
