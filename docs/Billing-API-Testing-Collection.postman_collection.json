{
  "info": {
    "name": "Billing API Testing Collection (Ordered)",
    "description": "Properly ordered collection for testing billing and invoice management API endpoints in the correct sequence",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "687f408d2353b22812099180",
      "type": "string"
    },
    {
      "key": "subscriptionId",
      "value": "68b5e9b8b568f4536207f5d6",
      "type": "string"
    },
    {
      "key": "invoiceId",
      "value": "{{invoiceId}}",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "68b599d614f31b31c052e400",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Phase 1: Setup and Health Check",
      "description": "Initial setup and system verification",
      "item": [
        {
          "name": "1.1 Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Verify system health before testing"
          }
        }
      ]
    },
    {
      "name": "Phase 2: Billing Profile Management",
      "description": "Create and manage billing profiles - Run these first",
      "item": [
        {
          "name": "2.1 Create Billing Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billingAddress\": {\n    \"street\": \"123 Main Street\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"postalCode\": \"400001\",\n    \"country\": \"IN\"\n  },\n  \"taxInformation\": {\n    \"taxId\": \"22AAAAA0000A1Z5\",\n    \"taxType\": \"GST\",\n    \"exemptionStatus\": false\n  },\n  \"preferences\": {\n    \"currency\": \"INR\",\n    \"invoiceDelivery\": \"email\",\n    \"autoRenewal\": true,\n    \"reminderDays\": 7,\n    \"language\": \"en\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}"
              ]
            },
            "description": "Create a billing profile for a customer - REQUIRED FIRST STEP"
          }
        },
        {
          "name": "2.2 Get Billing Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}"
              ]
            },
            "description": "Verify billing profile was created successfully"
          }
        },
        {
          "name": "2.3 Update Billing Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billingAddress\": {\n    \"street\": \"456 Updated Street\",\n    \"city\": \"Delhi\",\n    \"state\": \"Delhi\",\n    \"postalCode\": \"110001\",\n    \"country\": \"IN\"\n  },\n  \"preferences\": {\n    \"reminderDays\": 14,\n    \"language\": \"hi\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}"
              ]
            },
            "description": "Test updating billing profile"
          }
        }
      ]
    },
    {
      "name": "Phase 3: Payment Method Management",
      "description": "Add and manage payment methods - Run after billing profile creation",
      "item": [
        {
          "name": "3.1 Add Card Payment Method",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"methodId\": \"card_1234567890\",\n  \"type\": \"card\",\n  \"details\": {\n    \"last4\": \"4242\",\n    \"brand\": \"visa\",\n    \"expiryMonth\": 12,\n    \"expiryYear\": 2025,\n    \"holderName\": \"John Doe\",\n    \"nickname\": \"Primary Card\"\n  },\n  \"isDefault\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}/payment-methods",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}",
                "payment-methods"
              ]
            },
            "description": "Add first payment method (card) - will be set as default"
          }
        },
        {
          "name": "3.2 Add Bank Account Payment Method",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"methodId\": \"bank_1234567890\",\n  \"type\": \"bank_account\",\n  \"details\": {\n    \"accountNumber\": \"12345678901234\",\n    \"ifscCode\": \"HDFC0000123\",\n    \"bankName\": \"HDFC Bank\",\n    \"holderName\": \"John Doe\",\n    \"nickname\": \"Salary Account\"\n  },\n  \"isDefault\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}/payment-methods",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}",
                "payment-methods"
              ]
            },
            "description": "Add second payment method (bank account)"
          }
        },
        {
          "name": "3.3 Add UPI Payment Method",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"methodId\": \"upi_1234567890\",\n  \"type\": \"upi\",\n  \"details\": {\n    \"upiId\": \"john.doe@paytm\",\n    \"holderName\": \"John Doe\",\n    \"nickname\": \"Primary UPI\"\n  },\n  \"isDefault\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}/payment-methods",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}",
                "payment-methods"
              ]
            },
            "description": "Add third payment method (UPI)"
          }
        },
        {
          "name": "3.4 Set Default Payment Method",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}/payment-methods/bank_1234567890/default",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}",
                "payment-methods",
                "bank_1234567890",
                "default"
              ]
            },
            "description": "Change default payment method to bank account"
          }
        },
        {
          "name": "3.5 Remove Payment Method",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/billing/profiles/{{customerId}}/payment-methods/upi_1234567890",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "profiles",
                "{{customerId}}",
                "payment-methods",
                "upi_1234567890"
              ]
            },
            "description": "Remove UPI payment method"
          }
        }
      ]
    },
    {
      "name": "Phase 4: Invoice Generation",
      "description": "Generate invoices - Run after billing profile and payment methods are set up",
      "item": [
        {
          "name": "4.1 Generate Standard Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dueDays\": 30,\n  \"paymentTerms\": \"Net 30\",\n  \"notes\": \"Monthly subscription invoice\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/generate/{{subscriptionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "generate",
                "{{subscriptionId}}"
              ]
            },
            "description": "Generate first invoice - SAVE invoiceId from response"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save invoice ID for later use",
                  "if (pm.response.code === 201) {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.data && responseJson.data.invoice) {",
                  "        pm.environment.set('invoiceId', responseJson.data.invoice.paymentId);",
                  "        console.log('Saved invoiceId:', responseJson.data.invoice.paymentId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4.2 Test Idempotency",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-ID",
                "value": "test-idempotency-123"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dueDays\": 30,\n  \"paymentTerms\": \"Net 30\",\n  \"notes\": \"Monthly subscription invoice\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/generate/{{subscriptionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "generate",
                "{{subscriptionId}}"
              ]
            },
            "description": "Test idempotency - should return existing invoice"
          }
        },
        {
          "name": "4.3 Generate Proration Invoice (Upgrade)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"Premium Plan\",\n  \"amount\": 2000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/proration/{{subscriptionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "proration",
                "{{subscriptionId}}"
              ]
            },
            "description": "Generate proration invoice for plan upgrade"
          }
        },
        {
          "name": "4.4 Generate Proration Invoice (Downgrade)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"Basic Plan\",\n  \"amount\": 500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/proration/{{subscriptionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "proration",
                "{{subscriptionId}}"
              ]
            },
            "description": "Generate credit note for plan downgrade"
          }
        }
      ]
    },
    {
      "name": "Phase 5: Invoice Management",
      "description": "Manage and retrieve invoices - Run after invoice generation",
      "item": [
        {
          "name": "5.1 Get All Customer Invoices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/customer/{{customerId}}?limit=10&page=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "customer",
                "{{customerId}}"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "page",
                  "value": "0"
                }
              ]
            },
            "description": "Get all invoices for customer"
          }
        },
        {
          "name": "5.2 Get Pending Invoices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/customer/{{customerId}}?status=pending&limit=10&page=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "customer",
                "{{customerId}}"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "page",
                  "value": "0"
                }
              ]
            },
            "description": "Get only pending invoices"
          }
        },
        {
          "name": "5.3 Get Invoices by Date Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/customer/{{customerId}}?dateFrom=2024-01-01&dateTo=2024-12-31&limit=10&page=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "customer",
                "{{customerId}}"
              ],
              "query": [
                {
                  "key": "dateFrom",
                  "value": "2024-01-01"
                },
                {
                  "key": "dateTo",
                  "value": "2024-12-31"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "page",
                  "value": "0"
                }
              ]
            },
            "description": "Get invoices within date range"
          }
        },
        {
          "name": "5.4 Send Invoice Reminder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reminderType\": \"standard\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/invoices/{{invoiceId}}/reminder",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "invoices",
                "{{invoiceId}}",
                "reminder"
              ]
            },
            "description": "Send reminder for invoice (use invoiceId from step 4.1)"
          }
        }
      ]
    },
    {
      "name": "Phase 6: Recurring Billing",
      "description": "Test recurring billing functionality",
      "item": [
        {
          "name": "6.1 Dry Run Recurring Billing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bufferHours\": 24,\n  \"dryRun\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/billing/recurring",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "billing",
                "recurring"
              ]
            },
            "description": "Test what would be processed without actual execution"
          }
        },
        {
          "name": "6.2 Process Recurring Billing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "bufferHours\": 24,\n  \"dryRun\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/billing/recurring",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "billing",
                "recurring"
              ]
            },
            "description": "Actually process recurring billing"
          }
        }
      ]
    },
    {
      "name": "Phase 7: Payment Failure Handling",
      "description": "Test payment failure scenarios",
      "item": [
        {
          "name": "7.1 Handle Payment Failure (First Attempt)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Insufficient funds\",\n  \"retryable\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/payments/{{subscriptionId}}/{{paymentId}}/failure",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "payments",
                "{{subscriptionId}}",
                "{{paymentId}}",
                "failure"
              ]
            },
            "description": "Simulate first payment failure - should schedule retry"
          }
        },
        {
          "name": "7.2 Handle Payment Failure (Card Expired)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Card expired\",\n  \"retryable\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/billing/payments/{{subscriptionId}}/{{paymentId}}/failure",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "payments",
                "{{subscriptionId}}",
                "{{paymentId}}",
                "failure"
              ]
            },
            "description": "Simulate non-retryable payment failure"
          }
        }
      ]
    },
    {
      "name": "Phase 8: Statistics and Reporting",
      "description": "Test reporting functionality",
      "item": [
        {
          "name": "8.1 Get Global Billing Statistics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/billing/statistics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "billing",
                "statistics"
              ]
            },
            "description": "Get overall billing statistics"
          }
        },
         {
            "name": "8.2 Get Customer-Specific Statistics",
            "request": {
              "method": "GET",
              "url": {
                "raw": "{{baseUrl}}/billing/statistics?customerId={{customerId}}",
                "host": [
                  "{{baseUrl}}"
                ],
                "path": [
                  "billing",
                  "statistics"
                ],
                "query": [
                  {
                    "key": "customerId",
                    "value": "{{customerId}}"
                  }
                ]
              },
              "description": "Get statistics for specific customer"
            }
          },
          {
            "name": "8.3 Get Date-Filtered Statistics",
            "request": {
              "method": "GET",
              "url": {
                "raw": "{{baseUrl}}/billing/statistics?dateFrom=2024-01-01&dateTo=2024-12-31",
                "host": [
                  "{{baseUrl}}"
                ],
                "path": [
                  "billing",
                  "statistics"
                ],
                "query": [
                  {
                    "key": "dateFrom",
                    "value": "2024-01-01"
                  },
                  {
                    "key": "dateTo",
                    "value": "2024-12-31"
                  }
                ]
              },
              "description": "Get statistics for date range"
            }
          },
          {
            "name": "8.4 Get Overdue Invoices",
            "request": {
              "method": "GET",
              "url": {
                "raw": "{{baseUrl}}/billing/invoices/overdue?limit=50",
                "host": [
                  "{{baseUrl}}"
                ],
                "path": [
                  "billing",
                  "invoices",
                  "overdue"
                ],
                "query": [
                  {
                    "key": "limit",
                    "value": "50"
                  }
                ]
              },
              "description": "Get all overdue invoices"
            }
          }
        
        ]
      },
      {
        "name": "Phase 9: Error Testing",
        "description": "Test error scenarios and validation",
        "item": [
          {
            "name": "9.1 Invalid Billing Address",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"billingAddress\": {\n    \"street\": \"123\",\n    \"city\": \"A\",\n    \"state\": \"\",\n    \"postalCode\": \"12\",\n    \"country\": \"INVALID\"\n  }\n}"
              },
              "url": {
                "raw": "{{baseUrl}}/billing/profiles/test_invalid_customer",
                "host": [
                  "{{baseUrl}}"
                ],
                "path": [
                  "billing",
                  "profiles",
                  "test_invalid_customer"
                ]
              },
              "description": "Test validation errors - should return 400"
            }
          },
          {
            "name": "9.2 Non-existent Customer",
            "request": {
              "method": "GET",
              "url": {
                "raw": "{{baseUrl}}/billing/profiles/nonexistent_customer_id",
                "host": [
                  "{{baseUrl}}"
                ],
                "path": [
                  "billing",
                  "profiles",
                  "nonexistent_customer_id"
                ]
              },
              "description": "Test 404 error - should return 404"
            }
          },
          {
            "name": "9.3 Invalid Payment Method",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"methodId\": \"invalid_method\",\n  \"type\": \"invalid_type\",\n  \"details\": {}\n}"
              },
              "url": {
                "raw": "{{baseUrl}}/billing/profiles/{{customerId}}/payment-methods",
                "host": [
                  "{{baseUrl}}"
                ],
                "path": [
                  "billing",
                  "profiles",
                  "{{customerId}}",
                  "payment-methods"
                ]
              },
              "description": "Test invalid payment method - should return 400"
            }
          }
        ]
      }
    ],
    "event": [
      {
        "listen": "prerequest",
        "script": {
          "type": "text/javascript",
          "exec": [
            "// Set correlation ID for tracking",
            "if (!pm.request.headers.has('X-Correlation-ID')) {",
            "    pm.request.headers.add({",
            "        key: 'X-Correlation-ID',",
            "        value: pm.variables.replaceIn('{{$randomUUID}}').substring(0, 8)",
            "    });",
            "}"
          ]
        }
      },
      {
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "// Basic response validation for successful requests",
            "if (pm.response.code < 400) {",
            "    pm.test('Status code is successful', function () {",
            "        pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]);",
            "    });",
            "    ",
            "    pm.test('Response has correlation ID', function () {",
            "        const jsonData = pm.response.json();",
            "        pm.expect(jsonData.request).to.have.property('correlationId');",
