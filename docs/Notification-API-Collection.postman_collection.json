            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"workflowId\": \"welcome-email\",\n  \"payload\": {\n    \"userName\": \"John Doe\",\n    \"verificationUrl\": \"https://example.com/verify?token=abc123xyz\",\n    \"companyName\": \"Acme Corporation\",\n    \"supportEmail\": \"support@acme.com\"\n  },\n  \"channels\": [\"email\", \"in_app\"],\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/send",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "notifications",
                "send"
              ]
            }
